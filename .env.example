# Переменные окружения для MusicFlow
# Скопируй этот файл как .env и заполни значения

# ── ОБЯЗАТЕЛЬНО ──────────────────────────────────────────
# Секретный ключ (минимум 32 символа, случайная строка)
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=замени-на-случайную-строку-минимум-32-символа

# Режим отладки: 1 = включён (только для разработки!), 0 = выключен
FLASK_DEBUG=0

# ── DISCOGS API ───────────────────────────────────────────
# Получить токен: https://www.discogs.com/settings/developers
# Нажми "Generate new token"
DISCOGS_TOKEN=замени-на-свой-токен-discogs
